# ---- Neon Postgres ----
# Pooled connection (runtime, via @prisma/adapter-neon in lib/prisma.ts)
DATABASE_URL="postgresql://USER:PASSWORD@YOUR-PROJECT-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
# Direct (non-pooled) connection — used by prisma migrate (prisma.config.ts)
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@YOUR-PROJECT.REGION.aws.neon.tech/neondb?sslmode=require"

# ---- Auth.js ----
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=""

# ---- Resend (transactional email) ----
# Used for password reset (Phase A1) and contact notifications (Phase B6).
RESEND_API_KEY=""
# Where a new /contact submission gets emailed. Resend's sandbox sender
# (onboarding@resend.dev, see lib/mail.ts) can only deliver to the email
# address the Resend account itself was created with, until a custom
# domain is verified.
CONTACT_NOTIFICATION_EMAIL=""
